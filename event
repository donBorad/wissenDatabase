// ── EVENT MODEL ────────────────────────────────────────
const EventModel = (() => {
  let events = [];
  return {
    getAll: () => events,
    async load() {
      const res = await fetch('api.php?type=event');
      events = await res.json();
    },
    async add(data) {
      const ev = { id: Date.now(), ...data };
      await fetch('api.php?type=event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(ev)
      });
      events.unshift(ev);
      return ev;
    },
    async update(id, data) {
      await fetch(`api.php?type=event&id=${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      events = events.map(e => e.id === id ? { ...e, ...data } : e);
    },
    async remove(id) {
      await fetch(`api.php?type=event&id=${id}`, { method: 'DELETE' });
      events = events.filter(e => e.id !== id);
    },
    get: (id) => events.find(e => e.id === id)
  };
})();

// ── EVENT VIEW ─────────────────────────────────────────
const EventView = {
  list:       document.getElementById('issueList'),
  modal:      document.getElementById('eventModal'),
  modalTitle: document.getElementById('eventModalTitle'),
  eTitle:     document.getElementById('eTitle'),
  eType:      document.getElementById('eType'),
  eLocation:  document.getElementById('eLocation'),
  eInvitees:  document.getElementById('eInvitees'),
  eDate:      document.getElementById('eDate'),
  eDuration:  document.getElementById('eDuration'),
  ePriority:  document.getElementById('ePriority'),
  eDesc:      document.getElementById('eDesc'),
  eOutcome:   document.getElementById('eOutcome'),
  eActions:   document.getElementById('eActions'),
  eFollowup:  document.getElementById('eFollowup'),
  eReporter:  document.getElementById('eReporter'),

  fmt(iso) {
    return new Date(iso).toLocaleString('en-GB', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
  },

  esc(s) {
    return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  },

  renderAll(events) {
    this.list.innerHTML = '';
    const empty = document.getElementById('empty');
    if (!events.length) { empty.classList.add('show'); return; }
    empty.classList.remove('show');
    events.forEach(e => this.list.appendChild(this.card(e)));
  },

  card(e) {
    const el = document.createElement('div');
    el.className = 'card';
    el.dataset.eid = e.id;
    el.innerHTML = `
      <div class="card-header">
        <div class="card-title">${this.esc(e.title)}</div>
        <span class="badge ${e.priority}">${e.type}</span>
      </div>
      <div class="card-desc">${this.esc(e.desc)}</div>
      <div class="card-info">
        <span>📍 ${this.esc(e.location)}</span>
        <span>👥 ${this.esc(e.invitees)}</span>
        <span>⏱ ${e.duration ? e.duration + 'h' : '—'}</span>
        <span>👤 ${this.esc(e.reporter)}</span>
      </div>
      ${e.outcome ? `<div class="resolution-block"><div class="label">✓ Outcome</div><p>${this.esc(e.outcome)}</p></div>` : ''}
      ${e.actions ? `<div class="resolution-block" style="border-color:#e8ff47"><div class="label" style="color:var(--accent)">⚡ Actions</div><p>${this.esc(e.actions)}</p></div>` : ''}
      ${e.followup ? `<div style="margin-top:.5rem;font-size:11px;color:var(--muted);">📅 Follow-up: ${this.esc(e.followup)}</div>` : ''}
      <div class="card-meta">
        <span class="card-date">${this.fmt(e.date)}</span>
        <div class="card-actions">
          <button class="evtedit">Edit</button>
          <button class="evtdel">Delete</button>
        </div>
      </div>`;
    return el;
  },

  openModal(title = 'New Event', data = {}) {
    this.modalTitle.textContent = title;
    this.eTitle.value    = data.title    || '';
    this.eType.value     = data.type     || 'meeting';
    this.eLocation.value = data.location || 'teams';
    this.eInvitees.value = data.invitees || '';
    this.eDate.value     = data.date ? data.date.slice(0,16) : '';
    this.eDuration.value = data.duration || '';
    this.ePriority.value = data.priority || 'medium';
    this.eDesc.value     = data.desc     || '';
    this.eOutcome.value  = data.outcome  || '';
    this.eActions.value  = data.actions  || '';
    this.eFollowup.value = data.followup || '';
    this.eReporter.value = data.reporter || '';
    this.modal.classList.remove('hidden');
    this.eTitle.focus();
  },

  closeModal() { this.modal.classList.add('hidden'); },

  formData() {
    return {
      title:    this.eTitle.value.trim(),
      type:     this.eType.value,
      location: this.eLocation.value,
      invitees: this.eInvitees.value.trim(),
      date:     this.eDate.value ? new Date(this.eDate.value).toISOString() : new Date().toISOString(),
      duration: parseFloat(this.eDuration.value) || 0,
      priority: this.ePriority.value,
      desc:     this.eDesc.value.trim(),
      outcome:  this.eOutcome.value.trim(),
      actions:  this.eActions.value.trim(),
      followup: this.eFollowup.value,
      reporter: this.eReporter.value.trim()
    };
  }
};

// ── EVENT CONTROLLER ───────────────────────────────────
const EventController = (() => {
  let editId = null;
  let activeTab = 'issues';

  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeTab = btn.dataset.tab;
      if (activeTab === 'events') {
        document.getElementById('openModal').style.display = 'none';
        document.getElementById('openEventModal').style.display = 'inline-block';
        document.getElementById('filters').style.display = 'none';
        EventModel.load().then(() => EventView.renderAll(EventModel.getAll()));
      } else {
        document.getElementById('openModal').style.display = 'inline-block';
        document.getElementById('openEventModal').style.display = 'none';
        document.getElementById('filters').style.display = 'flex';
        Model.load().then(() => View.renderAll(Model.getAll()));
      }
    });
  });

  // Open modal
  document.getElementById('openEventModal').style.display = 'none';
  document.getElementById('openEventModal').addEventListener('click', () => {
    editId = null;
    EventView.openModal();
  });

  // Cancel
  document.getElementById('cancelEvent').addEventListener('click', EventView.closeModal.bind(EventView));
  document.getElementById('eventModal').addEventListener('click', e => {
    if (e.target === document.getElementById('eventModal')) EventView.closeModal();
  });

  // Save
  document.getElementById('saveEvent').addEventListener('click', async () => {
    const data = EventView.formData();
    if (!data.title || !data.desc || !data.reporter) {
      alert('Subject, description and reporter are required.');
      return;
    }
    if (editId) {
      await EventModel.update(editId, data);
      editId = null;
    } else {
      await EventModel.add(data);
    }
    EventView.closeModal();
    await EventModel.load();
    EventView.renderAll(EventModel.getAll());
  });

  // Card actions
  document.getElementById('issueList').addEventListener('click', async e => {
    const card = e.target.closest('.card');
    if (!card || !card.dataset.eid) return;
    const id = Number(card.dataset.eid);

    if (e.target.classList.contains('evtdel')) {
      if (confirm('Delete this event?')) {
        await EventModel.remove(id);
        await EventModel.load();
        EventView.renderAll(EventModel.getAll());
      }
    } else if (e.target.classList.contains('evtedit')) {
      editId = id;
      EventView.openModal('Edit Event', EventModel.get(id));
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') EventView.closeModal();
  });
})();
