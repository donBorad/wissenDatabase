        <span class="badge ${i.priority}">${i.priority}</span>
        <span>👤 Reporter: ${this.esc(i.reporter)}</span>
        <span>🏷 Owner: ${i.owner ? this.esc(i.owner) : '—'}</span>
        <span>📨 Via: ${this.esc(i.channel)}</span>
        <span>⏱ Time: ${i.time_spent ? i.time_spent + 'h' : '—'}</span>
      </div>
      ${i.image ? `<img src="${i.image}" class="card-image"/>` : ''}
      ${i.resolution ? `
      <div class="resolution-block">
        <div class="label">✓ Resolution</div>
        <p>${this.esc(i.resolution)}</p>
      </div>` : ''}
      <div class="card-meta">
        <span class="card-date">${this.fmt(i.date)}</span>
        <div class="card-actions">
          <button class="edit">Edit</button>
          <button class="toggle">${i.status === 'resolved' ? 'Reopen' : 'Resolve'}</button>
          <button class="del">Delete</button>
        </div>
      </div>`;
    return el;
  },

  openModal(title = 'New Issue', data = {}) {
    this.modalTitle.textContent = title;
    this.fTitle.value      = data.title      || '';
    this.fDesc.value       = data.desc       || '';
    this.fResolution.value = data.resolution || '';
    this.fReporter.value   = data.reporter   || '';
    this.fOwner.value      = data.owner      || '';
    this.fStatus.value     = data.status     || 'open';
    this.fPriority.value   = data.priority   || 'medium';
    this.fChannel.value    = data.channel    || 'email';
    this.fTimeSpent.value  = data.time_spent || '';
    this.fDate.value       = data.date ? data.date.slice(0,16) : '';
    issueImageUrl = data.image || '';
    document.getElementById('issuePreview').innerHTML = data.image ? `<img src="${data.image}"/>` : '';
    this.modal.classList.remove('hidden');
    this.fTitle.focus();
  },

  closeModal() {
    this.modal.classList.add('hidden');
    issueImageUrl = '';
    document.getElementById('issuePreview').innerHTML = '';
  },

  formData() {
    return {
      title:      this.fTitle.value.trim(),
      desc:       this.fDesc.value.trim(),
      resolution: this.fResolution.value.trim(),
      reporter:   this.fReporter.value.trim(),
      owner:      this.fOwner.value.trim(),
      status:     this.fStatus.value || 'open',
      priority:   this.fPriority.value || 'medium',
      channel:    this.fChannel.value || 'email',
      time_spent: parseFloat(this.fTimeSpent.value) || 0,
      image:      issueImageUrl,
      date:       this.fDate.value ? new Date(this.fDate.value).toISOString() : new Date().toISOString()
    };
  }
};

// ── EVENT VIEW ─────────────────────────────────────────
const EventView = {
  list:       document.getElementById('issueList'),
  empty:      document.getElementById('empty'),
  modal:      document.getElementById('eventModal'),
  modalTitle: document.getElementById('eventModalTitle'),
  eTitle:     document.getElementById('eTitle'),
  eType:      document.getElementById('eType'),
  eLocation:  document.getElementById('eLocation'),
  eInvitees:  document.getElementById('eInvitees'),
  eDate:      document.getElementById('eDate'),
  eDuration:  document.getElementById('eDuration'),
  ePriority:  document.getElementById('ePriority'),
  eDesc:      document.getElementById('eDesc'),
  eOutcome:   document.getElementById('eOutcome'),
  eActions:   document.getElementById('eActions'),
  eFollowup:  document.getElementById('eFollowup'),
  eReporter:  document.getElementById('eReporter'),

  fmt(iso) {
    return new Date(iso).toLocaleString('en-GB', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
  },

  esc(s) {
    return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  },

  renderAll(events) {
    this.list.innerHTML = '';
    if (!events.length) { this.empty.classList.add('show'); return; }
    this.empty.classList.remove('show');
    events.forEach(e => this.list.appendChild(this.card(e)));
  },

  card(e) {
    const el = document.createElement('div');
    el.className = 'card';
    el.dataset.eid = e.id;
    el.innerHTML = `
      <div class="card-header">
        <div class="card-title">${this.esc(e.title)}</div>
        <span class="badge ${e.priority}">${this.esc(e.type)}</span>
      </div>
      <div class="card-desc">${this.esc(e.desc)}</div>
      <div class="card-info">
        <span>📍 ${this.esc(e.location)}</span>
        <span>👥 ${this.esc(e.invitees) || '—'}</span>
        <span>⏱ ${e.duration ? e.duration + 'h' : '—'}</span>
        <span>👤 ${this.esc(e.reporter)}</span>
      </div>
      ${e.image ? `<img src="${e.image}" class="card-image"/>` : ''}
      ${e.outcome ? `<div class="resolution-block"><div class="label">✓ Outcome</div><p>${this.esc(e.outcome)}</p></div>` : ''}
      ${e.actions ? `<div class="resolution-block" style="border-color:var(--accent)"><div class="label" style="color:var(--accent)">⚡ Actions</div><p>${this.esc(e.actions)}</p></div>` : ''}
      ${e.followup ? `<div style="margin-top:.5rem;font-size:11px;color:var(--muted);">📅 Follow-up: ${this.esc(e.followup)}</div>` : ''}
      <div class="card-meta">
        <span class="card-date">${this.fmt(e.date)}</span>
        <div class="card-actions">
          <button class="evtedit">Edit</button>
          <button class="evtdel">Delete</button>
        </div>
      </div>`;
    return el;
  },

  openModal(title = 'New Event', data = {}) {
    this.modalTitle.textContent = title;
    this.eTitle.value    = data.title    || '';
    this.eType.value     = data.type     || 'meeting';
    this.eLocation.value = data.location || 'teams';
    this.eInvitees.value = data.invitees || '';
    this.eDate.value     = data.date ? data.date.slice(0,16) : '';
    this.eDuration.value = data.duration || '';
    this.ePriority.value = data.priority || 'medium';
    this.eDesc.value     = data.desc     || '';
    this.eOutcome.value  = data.outcome  || '';
    this.eActions.value  = data.actions  || '';
    this.eFollowup.value = data.followup || '';
    this.eReporter.value = data.reporter || '';
    eventImageUrl = data.image || '';
    document.getElementById('eventPreview').innerHTML = data.image ? `<img src="${data.image}"/>` : '';
    this.modal.classList.remove('hidden');
    this.eTitle.focus();
  },

  closeModal() {
    this.modal.classList.add('hidden');
    eventImageUrl = '';
    document.getElementById('eventPreview').innerHTML = '';
  },

  formData() {
    return {
      title:    this.eTitle.value.trim(),
      type:     this.eType.value,
      location: this.eLocation.value,
      invitees: this.eInvitees.value.trim(),
      date:     this.eDate.value ? new Date(this.eDate.value).toISOString() : new Date().toISOString(),
      duration: parseFloat(this.eDuration.value) || 0,
      priority: this.ePriority.value,
      desc:     this.eDesc.value.trim(),
      outcome:  this.eOutcome.value.trim(),
      actions:  this.eActions.value.trim(),
      followup: this.eFollowup.value,
      reporter: this.eReporter.value.trim(),
      image:    eventImageUrl
    };
  }
};

// ── CONTROLLER ─────────────────────────────────────────
const Controller = (() => {
  let filter      = 'all';
  let issueEditId = null;
  let eventEditId = null;
  let activeTab   = 'issues';

  const filtered = () => {
    const all = Model.getAll();
    if (filter === 'all') return all;
    if (filter === 'open') return all.filter(i => i.status === 'open' || i.status === 'in-progress');
    return all.filter(i => i.status === filter);
  };

  const renderIssues = () => View.renderAll(filtered());
  const renderEvents = () => EventView.renderAll(EventModel.getAll());

  // TABS
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeTab = btn.dataset.tab;
      if (activeTab === 'events') {
        document.getElementById('openModal').style.display      = 'none';
        document.getElementById('openEventModal').style.display = 'inline-block';
        document.getElementById('filters').style.display        = 'none';
        EventModel.load().then(renderEvents);
      } else {
        document.getElementById('openModal').style.display      = 'inline-block';
        document.getElementById('openEventModal').style.display = 'none';
        document.getElementById('filters').style.display        = 'flex';
        Model.load().then(renderIssues);
      }
    });
  });

  // FILTERS
  document.querySelectorAll('.filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filter = btn.dataset.filter;
      Model.load().then(renderIssues);
    });
  });

  // ISSUE MODAL
  document.getElementById('openModal').addEventListener('click', () => {
    issueEditId = null;
    View.openModal();
  });
  document.getElementById('cancelModal').addEventListener('click', View.closeModal.bind(View));
  document.getElementById('modal').addEventListener('click', e => {
    if (e.target === document.getElementById('modal')) View.closeModal();
  });

  // SAVE ISSUE
  document.getElementById('saveIssue').addEventListener('click', async () => {
    const data = View.formData();
    if (!data.title || !data.desc || !data.reporter) {
      alert('Title, description and reporter are required.');
      return;
    }
    if (issueEditId) {
      await Model.update(issueEditId, data);
      issueEditId = null;
    } else {
      await Model.add(data);
    }
    View.closeModal();
    await Model.load();
    renderIssues();
  });

  // EVENT MODAL
  document.getElementById('openEventModal').style.display = 'none';
  document.getElementById('openEventModal').addEventListener('click', () => {
    eventEditId = null;
    EventView.openModal();
  });
  document.getElementById('cancelEvent').addEventListener('click', EventView.closeModal.bind(EventView));
  document.getElementById('eventModal').addEventListener('click', e => {
    if (e.target === document.getElementById('eventModal')) EventView.closeModal();
  });

  // SAVE EVENT
  document.getElementById('saveEvent').addEventListener('click', async () => {
    const data = EventView.formData();
    if (!data.title || !data.desc || !data.reporter) {
      alert('Subject, description and reporter are required.');
      return;
    }
    if (eventEditId) {
      await EventModel.update(eventEditId, data);
      eventEditId = null;
    } else {
      await EventModel.add(data);
    }
    EventView.closeModal();
    await EventModel.load();
    renderEvents();
  });

  // CARD ACTIONS
  document.getElementById('issueList').addEventListener('click', async e => {
    const card = e.target.closest('.card');
    if (!card) return;

    if (card.dataset.eid) {
      const id = Number(card.dataset.eid);
      if (e.target.classList.contains('evtdel')) {
        if (confirm('Delete this event?')) {
          await EventModel.remove(id);
          await EventModel.load();
          renderEvents();
        }
      } else if (e.target.classList.contains('evtedit')) {
        eventEditId = id;
        EventView.openModal('Edit Event', EventModel.get(id));
      }
      return;
    }

    if (card.dataset.id) {
      const id = Number(card.dataset.id);
      if (e.target.classList.contains('del')) {
        if (confirm('Delete this issue?')) {
          await Model.remove(id);
          await Model.load();
          renderIssues();
        }
      } else if (e.target.classList.contains('edit')) {
        issueEditId = id;
        View.openModal('Edit Issue', Model.get(id));
      } else if (e.target.classList.contains('toggle')) {
        const issue = Model.get(id);
        await Model.update(id, {
          ...issue,
          status: issue.status === 'resolved' ? 'open' : 'resolved'
        });
        await Model.load();
        renderIssues();
      }
    }
  });

  // KEYBOARD
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { View.closeModal(); EventView.closeModal(); }
  });

  // INIT
  Model.load().then(renderIssues);
})();
