// ── ISSUE MODEL ────────────────────────────────────────
const Model = (() => {
  let issues = [];
  return {
    getAll: () => issues,
    async load() {
      const res = await fetch('api.php?type=issue');
      issues = await res.json();
    },
    async add(data) {
      const issue = { id: Date.now(), ...data };
      await fetch('api.php?type=issue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(issue)
      });
      issues.unshift(issue);
      return issue;
    },
    async update(id, data) {
      await fetch(`api.php?type=issue&id=${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      issues = issues.map(i => i.id === id ? { ...i, ...data } : i);
    },
    async remove(id) {
      await fetch(`api.php?type=issue&id=${id}`, { method: 'DELETE' });
      issues = issues.filter(i => i.id !== id);
    },
    get: (id) => issues.find(i => i.id === id)
  };
})();

