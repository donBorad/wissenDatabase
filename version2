<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Issue Log</title>
  <link rel="stylesheet" href="style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
</head>
<body>
  <header>
    <span class="logo">⬛ IssueLog</span>
    <button id="openModal">+ New Issue</button>
  </header>

  <main>
    <div id="filters">
      <button class="filter active" data-filter="all">All</button>
      <button class="filter" data-filter="open">Open</button>
      <button class="filter" data-filter="resolved">Resolved</button>
    </div>
    <div id="issueList"></div>
    <p id="empty">No issues yet. Create one.</p>
  </main>

  <div id="modal" class="hidden">
    <div class="modal-box">
      <h2 id="modalTitle">New Issue</h2>
      <input id="fTitle" placeholder="Title *" maxlength="100"/>
      <textarea id="fDesc" placeholder="Describe the issue *" rows="3"></textarea>
      <textarea id="fResolution" placeholder="Resolution (optional)" rows="2"></textarea>
      <input id="fReporter" placeholder="Reporter *" maxlength="100"/>
      <input id="fOwner" placeholder="Owner / Manager" maxlength="100"/>
      <select id="fStatus">
        <option value="open">Open</option>
        <option value="in-progress">In Progress</option>
        <option value="resolved">Resolved</option>
      </select>
      <select id="fPriority">
        <option value="low">Low</option>
        <option value="medium">Medium</option>
        <option value="high">High</option>
        <option value="critical">Critical</option>
      </select>
      <select id="fChannel">
        <option value="email">Email</option>
        <option value="teams">Teams</option>
        <option value="verbal">Verbal</option>
      </select>
      <input id="fTimeSpent" type="number" min="0" step="0.5" placeholder="Time spent (hours)"/>
      <label style="color:var(--muted);font-size:12px;">Created At</label>
      <input id="fDate" type="datetime-local"/>
      <div class="modal-actions">
        <button id="cancelModal" class="ghost">Cancel</button>
        <button id="saveIssue">Save</button>
      </div>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>
