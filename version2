*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0d0d0d;
  --surface: #161616;
  --card: #1e1e1e;
  --border: #2a2a2a;
  --accent: #e8ff47;
  --text: #f0f0f0;
  --muted: #666;
  --open: #ff6b6b;
  --resolved: #6bffb8;
  --radius: 8px;
  --mono: 'JetBrains Mono', monospace;
  --display: 'Syne', sans-serif;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--mono);
  font-size: 14px;
  min-height: 100vh;
}

header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.2rem 2rem;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  background: var(--bg);
  z-index: 10;
}

.logo {
  font-family: var(--display);
  font-size: 1.3rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--accent);
}

header button {
  background: var(--accent);
  color: #000;
  border: none;
  padding: 0.5rem 1.1rem;
  font-family: var(--mono);
  font-weight: 600;
  font-size: 13px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: opacity .15s;
}
header button:hover { opacity: .85; }

main {
  max-width: 780px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

#filters {
  display: flex;
  gap: .5rem;
  margin-bottom: 1.5rem;
}

.filter {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 12px;
  padding: .35rem .85rem;
  border-radius: 20px;
  cursor: pointer;
  transition: all .15s;
}
.filter.active, .filter:hover {
  border-color: var(--accent);
  color: var(--accent);
}

#empty {
  color: var(--muted);
  text-align: center;
  margin-top: 4rem;
  font-size: 13px;
  display: none;
}
#empty.show { display: block; }

.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.1rem 1.3rem;
  margin-bottom: .8rem;
  animation: fadeIn .2s ease;
}
.card:hover { border-color: #3a3a3a; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
}

.card-title {
  font-family: var(--display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  flex: 1;
}

.badge {
  font-size: 10px;
  font-weight: 600;
  padding: .2rem .6rem;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: .05em;
  flex-shrink: 0;
}
.badge.open        { background: #ff6b6b22; color: var(--open);    border: 1px solid var(--open); }
.badge.in-progress { background: #ffaa0022; color: #ffaa00;        border: 1px solid #ffaa00; }
.badge.resolved    { background: #6bffb822; color: var(--resolved); border: 1px solid var(--resolved); }
.badge.low         { background: #ffffff11; color: #aaa;            border: 1px solid #aaa; }
.badge.medium      { background: #e8ff4722; color: var(--accent);   border: 1px solid var(--accent); }
.badge.high        { background: #ff944422; color: #ff9444;         border: 1px solid #ff9444; }
.badge.critical    { background: #ff6b6b22; color: var(--open);     border: 1px solid var(--open); }

.card-desc {
  margin-top: .55rem;
  color: #aaa;
  line-height: 1.6;
  white-space: pre-wrap;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  margin-top: .6rem;
  align-items: center;
}

.card-info span {
  color: var(--muted);
  font-size: 11px;
}

.resolution-block {
  margin-top: .8rem;
  padding: .7rem 1rem;
  background: #6bffb808;
  border-left: 3px solid var(--resolved);
  border-radius: 0 var(--radius) var(--radius) 0;
}
.resolution-block .label {
  font-size: 10px;
  color: var(--resolved);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: .3rem;
  font-weight: 600;
}
.resolution-block p { color: #ccc; line-height: 1.6; white-space: pre-wrap; }

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: .9rem;
}

.card-date { color: var(--muted); font-size: 11px; }

.card-actions { display: flex; gap: .4rem; }

.card-actions button {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 11px;
  padding: .25rem .65rem;
  border-radius: 5px;
  cursor: pointer;
  transition: all .15s;
}
.card-actions button:hover { border-color: var(--accent); color: var(--accent); }
.card-actions .del:hover   { border-color: var(--open);   color: var(--open); }

#modal {
  position: fixed;
  inset: 0;
  background: #000a;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4px);
}
#modal.hidden { display: none; }

.modal-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.8rem;
  width: 100%;
  max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: .9rem;
}

.modal-box h2 {
  font-family: var(--display);
  font-size: 1.2rem;
  font-weight: 800;
  letter-spacing: -.02em;
}

.modal-box input,
.modal-box textarea,
.modal-box select {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--mono);
  font-size: 13px;
  padding: .65rem .9rem;
  outline: none;
  resize: vertical;
  transition: border-color .15s;
  width: 100%;
}
.modal-box input:focus,
.modal-box textarea:focus,
.modal-box select:focus { border-color: var(--accent); }

.modal-box select option { background: var(--card); }

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: .6rem;
  margin-top: .3rem;
}

.modal-actions button {
  font-family: var(--mono);
  font-size: 13px;
  padding: .5rem 1.2rem;
  border-radius: var(--radius);
  cursor: pointer;
  transition: opacity .15s;
  border: none;
}
#saveIssue { background: var(--accent); color: #000; font-weight: 600; }
#saveIssue:hover, #cancelModal:hover { opacity: .8; }
.ghost { background: transparent; border: 1px solid var(--border) !important; color: var(--muted); }
